{
    "api_settings": {
        "openrouter": {
            "provider": "openrouter",
            "url": "https://openrouter.ai/api/v1/chat/completions",
            "key": "${OPENROUTER_API_KEY}",
            "models": {
                "deepseek_v3.1": {
                    "model": "deepseek/deepseek-chat-v3.1",
                    "translation_config": {
                        "source_language": "ja",
                        "target_language": "zh-TW",
                        "batch_size": 100,
                        "max_concurrent_requests": 2,
                        "enable_validation": true,
                        "max_retries": 3,
                        "retry_delay": 4,
                        "batch_failed_retry_count": 3,
                        "empty_threshold": 0.01
                    }
                },
                "deepseek_v3_0324": {
                    "model": "deepseek/deepseek-chat-v3-0324",
                    "translation_config": {
                        "source_language": "ja",
                        "target_language": "zh-TW",
                        "batch_size": 100,
                        "max_concurrent_requests": 2,
                        "enable_validation": true,
                        "max_retries": 3,
                        "retry_delay": 4,
                        "batch_failed_retry_count": 3,
                        "empty_threshold": 0.01
                    }
                }
            }
        },
        "anthropic": {
            "provider": "anthropic",
            "url": "https://api.anthropic.com/v1/messages",
            "key": "${ANTHROPIC_API_KEY}",
            "models": {
                "claude_3_5_sonnet": {
                    "model": "claude-3-5-sonnet-20241022",
                    "translation_config": {
                        "source_language": "ja",
                        "target_language": "zh-TW",
                        "batch_size": 50,
                        "max_concurrent_requests": 2,
                        "enable_validation": true,
                        "max_retries": 3,
                        "retry_delay": 4,
                        "batch_failed_retry_count": 3,
                        "empty_threshold": 0.01
                    }
                }
            }
        }
    },
    "default_translation_config": {
        "source_language": "ja",
        "target_language": "zh-TW",
        "batch_size": 100,
        "max_concurrent_requests": 2,
        "enable_validation": true,
        "max_retries": 3,
        "retry_delay": 4,
        "batch_failed_retry_count": 3,
        "empty_threshold": 0.01
    },
    "last_selected": {
        "api": "openrouter",
        "model": "deepseek_v3_0324"
    }
}
