{
    "default": {
        "api_settings": {
            "openrouter": {
                "provider": "openrouter",
                "url": "https://openrouter.ai/api/v1/chat/completions",
                "key": "${OPENROUTER_API_KEY}"
            },
            "API Yi": {
                "provider": "API Yi",
                "url": "https://api.apiyi.com/v1/chat/completions",
                "key": "${API_YI_KEY}"
            },
            "FreedomGPT": {
                "provider": "FreedomGPT",
                "url": "https://chat.freedomgpt.com/api/v1/chat/completions",
                "key": "${FREEDOMGPT_KEY}"
            }
        },
        "model_settings": {
            "(OR)deepseek_v3.1": {
                "model": "deepseek/deepseek-chat-v3.1"
            },
            "(Yi)deepseek-v3-0324": {
                "model": "deepseek-v3-0324"
            },
            "(FG)deepseek_v3.2": {
                "model": "deepseek-v3.2"
            },
            "(Yi)qwen3.5-flash-2026-02-23": {
                "model": "qwen3.5-flash-2026-02-23"
            }
        },
        "prompt_templates": {
            "system_prompt": "你是字幕翻譯AI，必須嚴格遵守以下格式：\n\n輸入格式：\"{序號}:{日文內容}\"\n輸出格式：\"{序號}:{中文翻譯}\"\n\n重要規則：\n1. 只輸出翻譯結果，不要確認或解釋\n2. 保留輸入中的特殊標記（如[[A-1]]），直接複製到輸出\n3. 翻譯風格：自然對話，台灣用語\n4. 嚴格禁止改變輸出格式，必須要有序號\n5. 輸出序號必須與輸入序號對應\n6. 不添加任何額外說明或註解",
            "user_prompt_template": "請翻譯以下日文字幕為繁體中文。\n\n翻譯要點：\n- 考慮前後字幕的上下文，確保句子完整性\n- 使用台灣日常用語\n- 保持原文的語氣和情感\n- 務必保持每行開頭的序號不變\n\n\n待翻譯內容：\n{subtitle_content}"
        },
        "translation_config": {
            "source_language": "ja",
            "target_language": "zh-TW",
            "batch_size": 100,
            "max_concurrent_requests": 2,
            "enable_validation": true,
            "max_retries": 3,
            "retry_delay": 4,
            "batch_failed_retry_count": 3,
            "empty_threshold": 0.01
        },
        "last_selected": {
            "api": "API Yi",
            "model": "(Yi)deepseek-v3-0324"
        }
    },
    "Universal": {
        "api_settings": {
            "openrouter": {
                "provider": "openrouter",
                "url": "https://openrouter.ai/api/v1/chat/completions",
                "key": "${OPENROUTER_API_KEY}"
            }
        },
        "model_settings": {
            "deepseek": {
                "model": "deepseek/deepseek-chat-v3.1"
            }
